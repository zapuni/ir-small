# =========================================================================
#  OFFLINE RAG COMPETITION — configuration template
#  Copy to .env and fill in your values:  cp .env.example .env
#  (Never commit .env — it may contain API keys.)
#
#  Recommended defaults below match the tuned setup. For the unknown-exam
#  strategy (which model/config per attempt, how to use the request logs),
#  see docs/COMPETITION_PLAYBOOK.md.
# =========================================================================

# ---- Identity (REQUIRED) -------------------------------------------------
STUDENT_ID=YOUR_MSSV_UPPERCASE

# =========================================================================
#  LLM — TWO MODES
# =========================================================================
# MODE 1: temporary OpenAI-compatible endpoint (dev / local Qwen host)
LLM_BASE_URL=https://your-llm-host/v1
LLM_API_KEY=your-api-key-or-none
LLM_MODEL_NAME=Qwen/Qwen3.5-4B
LLM_TEMPERATURE=0.0
LLM_PROFILE=auto
LLM_ENABLE_THINKING=false
LLM_MAX_TOKENS=96
LLM_TIMEOUT=25
LLM_MAX_RETRIES=0

# MODE 2: Teacher proxy (competition day)
# Set LLM_USE_PROXY=true or clear LLM_BASE_URL to use proxy + STUDENT_ID as key.
LLM_USE_PROXY=false
PROXY_BASE_URL=http://192.168.50.218:8000/api/v1/proxy
LLM_MODEL=gpt-4o-mini

# =========================================================================
#  Teacher Server
# =========================================================================
TEACHER_BASE_URL=http://192.168.50.218:8000/api/v1

# =========================================================================
#  Student server
# =========================================================================
HOST=0.0.0.0
PORT=5000
ASK_DEADLINE=45

# =========================================================================
#  Embedding model (Vietnamese & Multilingual models support)
# =========================================================================
# Choose your embedding model (just change this line and restart):
#
# Recommended DEFAULT (most robust across question types, fastest on CPU):
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  ⭐ DEFAULT
#
# VIETNAMESE-SPECIFIC MODELS (best on factoid: dates/numbers/names):
#   dangvantuan/vietnamese-embedding     (PhoBERT, 768 dim, ~99% on factoid test) ⭐
#   keepitreal/vietnamese-sbert          (small, 768 dim, strong on factoid)
#   AITeamVN/Vietnamese_Embedding        (BGE-M3, 1024 dim; big chunks, slower)
#   thanhtantran/Vietnamese_Embedding_v2 (BGE-M3 v2, 1024 dim)
#
# MULTILINGUAL MODELS (better on semantic / reasoning questions):
#   intfloat/multilingual-e5-base        (278M, 768 dim, proven)
#   jinaai/jina-embeddings-v5-text-nano  (239M, 512 dim, fast)
#   jinaai/jina-embeddings-v5-text-small (677M, 512 dim, better quality)
#
# WHICH TO PICK: keep the default until attempt #1 reveals the real questions
# (see logs/eval/). If they are factoid -> switch to dangvantuan/keepitreal;
# if semantic/reasoning -> keep paraphrase or try e5. See COMPETITION_PLAYBOOK.md.
# Models are cached per-folder, so you can switch freely. E5 models auto-add
# the required "query: " / "passage: " prefixes.

EMBED_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Cache directory for all embedding models (each model cached separately)
# Default: src/models (creates subdirectories per model automatically)
# EMBED_CACHE_DIR=

# Max sequence length (auto-detected per model, but you can override)
#   256 - fast, good for short texts (vietnamese-sbert, dangvantuan)
#   512 - balanced (BGE-M3, E5, Jina v5)
#   8192 - very long context (Jina v5 maximum)
EMBED_MAX_SEQ_LEN=256

EMBED_BATCH_SIZE=32

# =========================================================================
#  Chunking (adaptive based on embedding model)
# =========================================================================
# Fallback values when CHUNK_ADAPTIVE=false
CHUNK_SIZE_WORDS=180
CHUNK_OVERLAP_WORDS=40

# Enable adaptive chunking (recommended: true)
# Automatically optimizes chunk size and overlap based on embedding model:
#   - keepitreal/vietnamese-sbert (256 tok): 160 words, 45 overlap (27%)
#   - AITeamVN/Vietnamese_Embedding (512 tok): 320 words, 85 overlap (27%)
#   - jinaai/jina-embeddings-v5 (8192 tok): 600 words, 160 overlap (27%)
# Set to false to use manual CHUNK_SIZE_WORDS and CHUNK_OVERLAP_WORDS
CHUNK_ADAPTIVE=true

# =========================================================================
#  Retrieval (hybrid BM25 + dense, RRF fusion, MMR diversity)
#  + per-option exact-match evidence (search_mcq) — guarantees the chunk that
#    best matches EACH answer option (dates/emails/codes) is in context.
# =========================================================================
TOP_K_DENSE=20
TOP_K_BM25=20
TOP_K_CONTEXT=8
RRF_K=60
MMR_LAMBDA=0.35
# Context budget (8 fused + up to 4 per-option evidence chunks). Tuned for the
# compact default model (~80-word chunks). If you switch to a big-chunk model
# (e5 / AITeamVN, ~320-word chunks) raise to ~12000; if the proxy seq len is
# tight (~2048 tokens) lower to ~4500-5000.
CONTEXT_MAX_CHARS=6500
CONTEXT_MAX_CHUNK_CHARS=850
